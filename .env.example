# LogosWeb Environment Configuration

# Auth Mode: "personal" (single user, no OAuth) or "team" (Google OAuth)
NEXT_PUBLIC_AUTH_MODE=team
# NEXT_PUBLIC_PERSONAL_USER_EMAIL=user@example.com  # only for personal mode

# API
NEXT_PUBLIC_API_URL=http://localhost:8090
NEXT_PUBLIC_API_VERSION=v1

# Google OAuth (required for team mode only)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# NextAuth
NEXTAUTH_URL=http://localhost:8010
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
